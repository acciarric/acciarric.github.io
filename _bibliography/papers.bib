@article{AccShumSilv19,
abbr={jpaa},
bibtex_show={true},
title = {Engel sinks of fixed points in finite groups},
journal = {Journal of Pure and Applied Algebra},
volume = {223},
number = {11},
pages = {4592-4601},
year = {2019},
issn = {0022-4049},
doi = {https://doi.org/10.1016/j.jpaa.2019.02.006},
url = {https://www.sciencedirect.com/science/article/pii/S0022404919300404},
author = {Cristina Acciarri and Pavel Shumyatsky and Danilo Silveira},
keywords = {Finite groups, Automorphisms, Centralizers, Engel condition},
abstract = {For an element g of a group G, an Engel sink is a subset E(g) such that for every x∈G all sufficiently long commutators [x,g,g,…,g] belong to E(g). Let q be a prime, let m be a positive integer and A an elementary abelian group of order q2 acting coprimely on a finite group G. We show that if for each nontrivial element a in A and every element g∈CG(a) the cardinality of the smallest Engel sink E(g) is at most m, then the order of γ∞(G) is bounded in terms of m only. Moreover we prove that if for each a∈A∖{1} and every element g∈CG(a), the smallest Engel sink E(g) generates a subgroup of rank at most m, then the rank of γ∞(G) is bounded in terms of m and q only.}
}

