@article{AccLucch21,
abbr={dmath},
bibtex_show={true},
title={Genus, thickness and crossing number of graphs encoding the generating properties of finite groups},
journal={Discrete Mathematics},
volume={344},
number={4},
pages={112289},
year={2021},
issn={0012-365X},
