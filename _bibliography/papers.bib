number = {3},
pages = {461--469},
year = {2021},
issn = {1436-5081},
doi = {https://doi.org/10.1007/s00605-020-01479-4},
abstract = { Let $$G$$ be a finite group of odd order admitting an involutory automorphism $$\phi $$, and let $$G_{-\phi }$$be the set of elements of G transformed by $$\phi $$into their inverses. Note that $$[G,\phi ]$$is precisely the subgroup generated by $$G_{-\phi }$$. Suppose that each subgroup generated by a subset of $$G_{-\phi }$$can be generated by at most r elements. We show that the rank of $$[G,\phi ]$$is r-bounded.},
author = {Acciarri, Cristina and Shumyatsky, Pavel}
}

@article{AccLucch20,
abbr={mathnach},
bibtex_show={true},
author = {Acciarri, Cristina and Lucchini, Andrea},
title = {Graphs encoding the generating properties of a finite group},
